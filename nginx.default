upstream agent {
    server 0.0.0.0:8000;
}

server {

    listen 8080;
    client_max_body_size 10M;
    server_tokens off;

    # Security response headers. The agent is server-to-server only (no browser
    # callers), so these are no-ops at runtime for current consumers; declared
    # to satisfy outbound-traffic security baselines.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Content-Security-Policy "default-src 'self'; frame-ancestors 'none'" always;
    add_header Referrer-Policy "no-referrer" always;

    # Drop any upstream wildcard CORS header. Server-to-server callers don't
    # use CORS; not re-emitting one keeps the response free of any allow-origin
    # advertisement.
    proxy_hide_header Access-Control-Allow-Origin;

    location / {
        proxy_pass http://agent;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_redirect off;
    }

    location /static/ {
        root /code/;
    }

}

access_log /dev/stdout;
